<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F8F4F4"
    android:backgroundTint="#1A711E94"
    android:textAlignment="center"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/vertical_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <HorizontalScrollView
            android:layout_width="4dp"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical" />
        </HorizontalScrollView>

        <SearchView
            android:id="@+id/search"
            android:layout_width="123dp"
            android:layout_height="90dp"
            android:background="#54F6E1E1"
            android:queryHint="search product,brands and categories">

        </SearchView>

        <ImageView
            android:id="@+id/phone"
            android:layout_width="match_parent"
            android:layout_height="467dp"
            tools:srcCompat="@drawable/frigde" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="46dp">

            <TextView
                android:id="@+id/text_1"
                android:layout_width="387dp"
                android:layout_height="38dp"
                android:background="#E2DCDC"
                android:text="flash sale / time left 2hrs"
                android:textAlignment="center"
                tools:layout_editor_absoluteY="4dp" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/clearance_sale"
            android:layout_width="match_parent"
            android:layout_height="28dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </androidx.cardview.widget.CardView>

        <ImageView
            android:id="@+id/jumia_logo"
            android:layout_width="match_parent"
            android:layout_height="138dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:srcCompat="@drawable/phone" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="45dp">

            <TextView
                android:id="@+id/leaf"
                android:layout_width="match_parent"
                android:layout_height="31dp"
                android:background="#C8BEBE"
                android:text="flash sales /time left 6hrs 30mins"
                android:textAlignment="center" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/browse"
            android:layout_width="match_parent"
            android:layout_height="59dp"
            android:layout_marginEnd="16dp"
            android:layout_marginRight="16dp"
            android:layout_weight="1"
            android:background="#E6C2C2"
            android:text="search for product,brand and categories"
            android:textAlignment="center"
            app:layout_constraintEnd_toEndOf="parent" />

        <HorizontalScrollView
            android:id="@+id/home"
            android:layout_width="match_parent"
            android:layout_height="30dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical" />
        </HorizontalScrollView>

        <androidx.cardview.widget.CardView
            android:id="@+id/view"
            android:layout_width="553dp"
            android:layout_height="411dp">

            <ImageView
                android:id="@+id/product"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:srcCompat="@drawable/handler" />

            <LinearLayout
                android:id="@+id/layout"
                android:layout_width="553dp"
                android:layout_height="387dp"
                android:orientation="vertical">

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/logo"
            android:layout_width="match_parent"
            android:layout_height="302dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/imageView9"
                android:layout_width="168dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                tools:srcCompat="@drawable/stove" />

            <TextView
                android:id="@+id/believe"
                android:layout_width="111dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#CFE0CDEF"
                android:text="jumia is ranked as the number one online shop across Ghana "
                android:textAlignment="center" />

            <ImageView
                android:id="@+id/imageView10"
                android:layout_width="132dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                tools:srcCompat="@drawable/kitchen" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>